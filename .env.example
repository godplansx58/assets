# Copy this file to .env and fill in your values
# NEVER share your private key with anyone!

# Your MetaMask wallet private key (export from MetaMask > Account Details > Export Private Key)
PRIVATE_KEY=your_private_key_here

# Sepolia RPC URL (default works without API key)
SEPOLIA_RPC=https://rpc.sepolia.org

# JWT + DB
MONGODB_URI=your_mongodb_uri_here
JWT_SECRET=your_jwt_secret_here

# Telegram Bot
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here
TELEGRAM_ADMIN_CHAT_ID=your_admin_chat_id_here
TELEGRAM_ADMIN_USERNAME=your_admin_username_here
TELEGRAM_SETUP_KEY=your_random_setup_key_here
